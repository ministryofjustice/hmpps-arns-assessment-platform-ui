{
  "name": "hmpps-arns-assessment-platform-ui",
  "version": "0.0.1",
  "description": "HMPPS Arns Assessment Platform Ui",
  "repository": "git@github.com:ministryofjustice/hmpps-arns-assessment-platform-ui.git",
  "license": "MIT",
  "scripts": {
    "prepare": "hmpps-precommit-hooks-prepare",
    "watch-ts": "tsc -w",
    "build": "node esbuild/esbuild.js",
    "start": "node $NODE_OPTIONS dist/server.js | bunyan -o short",
    "start:dev": "node esbuild/esbuild.js --watch",
    "start-feature": "node $NODE_DEBUG_OPTION --env-file=feature.env dist/server.js | bunyan -o short",
    "lint": "eslint . --cache --max-warnings 0",
    "lint-fix": "eslint . --cache --max-warnings 0 --fix",
    "typecheck": "tsc && tsc -p integration_tests",
    "test": "jest",
    "test:ci": "jest --runInBand",
    "test:coverage": "jest --coverage",
    "security_audit": "npx audit-ci --config audit-ci.json",
    "int-test": "npx playwright test",
    "int-test-ui": "npx playwright test --ui",
    "int-test-init:ci": "npx playwright install",
    "clean": "rm -rf dist test_results",
    "rebuild": "npm run clean && npm i && npm run build",
    "precommit:secrets": "gitleaks git --pre-commit --redact --staged --verbose --config .gitleaks/config.toml",
    "precommit:lint": "node_modules/.bin/lint-staged",
    "precommit:verify": "npm run typecheck && npm test",
    "setup": "npm ci && hmpps-npm-script-run-allowlist"
  },
  "engines": {
    "node": "^24",
    "npm": "^11"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1075.0",
    "@faker-js/faker": "10.5.0",
    "@flipt-io/flipt-client-js": "0.5.0",
    "@microsoft/applicationinsights-clickanalytics-js": "3.4.2",
    "@microsoft/applicationinsights-web": "3.4.2",
    "@ministryofjustice/frontend": "9.0.0",
    "@ministryofjustice/hmpps-audit-client": "^1.1.3",
    "@ministryofjustice/hmpps-auth-clients": "^1.0.2",
    "@ministryofjustice/hmpps-azure-telemetry": "0.0.1-alpha.4",
    "@ministryofjustice/hmpps-forge": "0.1.0-alpha.22",
    "@ministryofjustice/hmpps-monitoring": "^1.1.0",
    "@ministryofjustice/hmpps-rest-client": "^1.2.1",
    "accessible-autocomplete": "^3.0.1",
    "body-parser": "^2.3.0",
    "bunyan": "^1.8.15",
    "bunyan-format": "^0.2.1",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "connect-redis": "^9.0.0",
    "cookie-parser": "1.4.7",
    "csrf-sync": "^4.2.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "govuk-frontend": "6.3.0",
    "helmet": "^8.2.0",
    "highlight.js": "^11.11.1",
    "http-errors": "^2.0.1",
    "jwt-decode": "^4.0.0",
    "luxon": "3.7.2",
    "markdown-it": "14.2.0",
    "markdown-it-attrs": "4.5.0",
    "nocache": "^4.0.0",
    "nunjucks": "^3.2.4",
    "passport": "^0.7.0",
    "passport-oauth2": "^1.8.0",
    "redis": "^5.12.1",
    "superagent": "^10.3.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "mocha": {
      "serialize-javascript": "^7.0.6",
      "diff": "^8.0.3"
    },
    "@yikes2000/prettier-plugin-merge-extras": {
      "diff": "5.2.2"
    },
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.15"
    },
    "@aws-sdk/xml-builder": {
      "fast-xml-parser": "5.9.3"
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@jgoz/esbuild-plugin-typecheck": "^4.0.4",
    "@ministryofjustice/eslint-config-hmpps": "^2.0.0-alpha.2",
    "@ministryofjustice/hmpps-npm-script-allowlist": "0.0.6",
    "@ministryofjustice/hmpps-precommit-hooks": "^2.0.2",
    "@playwright/test": "1.61.1",
    "@tsconfig/node24": "24.0.4",
    "@types/bunyan": "^1.8.11",
    "@types/bunyan-format": "^0.2.9",
    "@types/compression": "^1.8.1",
    "@types/connect-flash": "0.0.40",
    "@types/cookie-parser": "1.4.10",
    "@types/express-session": "^1.19.0",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/jest-when": "^3.5.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "3.7.2",
    "@types/markdown-it": "14.1.2",
    "@types/markdown-it-attrs": "4.1.3",
    "@types/node": "24.13.2",
    "@types/nunjucks": "^3.2.6",
    "@types/passport": "^1.0.17",
    "@types/passport-oauth2": "^1.8.0",
    "@types/pg": "^8.20.0",
    "@types/superagent": "^8.1.10",
    "@types/supertest": "^7.2.0",
    "@yikes2000/prettier-plugin-merge-extras": "^0.7.3-extras.2",
    "audit-ci": "^7.1.0",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.28.1",
    "esbuild-plugin-clean": "^1.0.1",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-plugin-manifest": "^1.0.5",
    "esbuild-sass-plugin": "^3.7.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "glob": "^13.0.6",
    "jest": "^30.4.2",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "^17.0.0",
    "jest-when": "^3.7.0",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "^16.4.0",
    "mocha-junit-reporter": "^2.2.1",
    "nock": "^14.0.16",
    "pg": "^8.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  }
}
