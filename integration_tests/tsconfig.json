{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": ["es2022", "dom"],
    "types": ["@playwright/test"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "baseUrl": ".",
    "paths": {
      "@server/*": ["../server/*"]
    }
  },
  "include": ["**/*.ts"]
}
